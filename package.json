{
    "name": "secure-store-redis",
    "version": "4.1.1",
    "description": "A simple wrapper to encrypt and decrypt data stored in Redis",
    "license": "MIT",
    "private": false,
    "type": "module",
    "packageManager": "bun@1.x",
    "engines": {
        "node": ">=20",
        "bun": ">=1.0.0"
    },
    "keywords": [
        "redis",
        "secure",
        "store",
        "encrypt",
        "decrypt",
        "client",
        "database"
    ],
    "author": {
        "name": "Nick Jennings",
        "email": "nick@silverbucket.net"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "bun": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "scripts": {
        "test": "bun test",
        "test:node": "node --import tsx --test src/index.test.ts",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "build:js": "bun build ./src/index.ts --outdir ./dist --target node --format esm",
        "build:types": "tsc",
        "build": "bun run build:js && bun run build:types",
        "release": "./scripts/release.sh",
        "prepublishOnly": "bun run build"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.0.0",
        "@types/bun": "^1.3.6",
        "@types/debug": "4.1.13",
        "@types/node": "25.5.0",
        "tsx": "^4.21.0",
        "typescript": "6.0.2"
    },
    "repository": {
        "type": "git",
        "url": "git://github.com/silverbucket/secure-store-redis.git"
    },
    "readmeFilename": "README.md",
    "bugs": {
        "url": "https://github.com/silverbucket/secure-store-redis/issues"
    },
    "homepage": "https://github.com/silverbucket/secure-store-redis",
    "dependencies": {
        "debug": "4.4.3",
        "ioredis": "^5.9.2"
    }
}
