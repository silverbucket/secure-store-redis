{
    "name": "secure-store-redis",
    "version": "4.0.0",
    "description": "A simple wrapper to encrypt and decrypt data stored in Redis",
    "license": "MIT",
    "private": false,
    "type": "module",
    "keywords": [
        "redis",
        "secure",
        "store",
        "encrypt",
        "decrypt",
        "client",
        "database"
    ],
    "author": {
        "name": "Nick Jennings",
        "email": "nick@silverbucket.net"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "bun": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "scripts": {
        "test": "bun test",
        "test:node": "node --import tsx --test src/index.test.ts",
        "lint": "prettier --check . && eslint --max-warnings 0 .",
        "lint:fix": "prettier --write .",
        "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm && bun x tsc --emitDeclarationOnly",
        "prepublishOnly": "bun run build"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.3",
        "@eslint/js": "^9.39.2",
        "@types/bun": "^1.3.6",
        "@types/debug": "4.1.12",
        "@types/eslint": "9.6.1",
        "@types/node": "22.13.5",
        "@typescript-eslint/eslint-plugin": "8.24.1",
        "@typescript-eslint/parser": "8.24.1",
        "eslint": "9.21.0",
        "eslint-plugin-security-node": "1.1.4",
        "globals": "^16.5.0",
        "prettier": "3.5.2",
        "tsx": "^4.21.0",
        "typescript": "5.7.3"
    },
    "repository": {
        "type": "git",
        "url": "git://github.com/silverbucket/secure-store-redis.git"
    },
    "readmeFilename": "README.md",
    "bugs": {
        "url": "https://github.com/silverbucekt/secure-store-redis/issues"
    },
    "homepage": "https://github.com/silverbucket/secure-store-redis",
    "dependencies": {
        "debug": "4.4.0",
        "ioredis": "^5.9.2"
    }
}
